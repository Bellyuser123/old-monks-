NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Get free key: https://build.nvidia.com
# Do NOT commit your real API key to git!
# Copy this to .env and add your key, then git add .env.example (gitignore .env)

NODE_ENV=development
PORT=5000

# Model used: meta/llama-3.3-70b-instruct (via NVIDIA NIM OpenAI-compatible API)
# Docs: https://docs.api.nvidia.com/nim/reference/llm-apis
